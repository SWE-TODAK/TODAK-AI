{
  "type": "object",
  "title": "SummaryResult",
  "properties": {
    "content": {
      "type": "object",
      "properties": {
        "patient_summary": { "type": "string" },
        "diagnosis": {
          "type": "array",
          "items": { "type": "string" }
        },
        "prescriptions": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "dose": { "type": "string" },
              "frequency": { "type": "string" }
            },
            "required": ["name"]
          }
        },
        "instructions": {
          "type": "array",
          "items": { "type": "string" }
        },
        "meta": {
          "type": "object",
          "properties": {
            "language": { "type": "string" },
            "version": { "type": "string" },
            "model": { "type": "string" }
          },
          "required": ["language", "version"]
        }
      },
      "required": ["patient_summary"]
    },
    "tags": {
      "type": "object",
      "properties": {
        "keywords": {
          "type": "array",
          "items": { "type": "string" }
        },
        "risk_level": {
          "type": "string",
          "enum": ["LOW", "MEDIUM", "HIGH"]
        }
      }
    }
  },
  "required": ["content"]
}
