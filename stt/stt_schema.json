{
  "type": "object",
  "title": "SttResultData",
  "description": "/internal/transcriptions 성공 응답의 data 필드 스키마",
  "properties": {
    "recordingId": {
      "type": "string",
      "description": "STT가 수행된 녹음 ID"
    },
    "consultationId": {
      "type": "string",
      "description": "해당 녹음이 속한 진료 ID"
    },
    "duration": {
      "type": "integer",
      "description": "전체 음성 길이 (초 단위)"
    },
    "language": {
      "type": "string",
      "description": "인식된 언어 코드 (예: ko, en)"
    },
    "sttResult": {
      "type": "array",
      "description": "STT 결과 텍스트 배열",
      "items": {
        "type": "object",
        "properties": {
          "text": {
            "type": "string",
            "description": "변환된 STT 텍스트"
          }
        },
        "required": ["text"]
      }
    },
    "meta": {
      "type": "object",
      "description": "STT 메타 정보",
      "properties": {
        "provider": {
          "type": "string"
        },
        "model": {
          "type": "string"
        },
        "processedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["provider", "model", "processedAt"]
    }
  },
  "required": ["recordingId", "consultationId", "sttResult"]
}
